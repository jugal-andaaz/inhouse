<script>
(function () {
    'use strict'; 
    var ZEBRA_PATTERNS    = ['Zebra ZP 500 (ZPL)', 'ZP 500', 'Zebra ZP', 'Zebra'];
    var _zebraPrinterName   = null; // cached after first lookup
    var _defaultPrinterName = null; // cached after first lookup (for invoice A4 printer)

    async function _findZebraPrinter() {
        if (_zebraPrinterName) return _zebraPrinterName;
        for (var i = 0; i < ZEBRA_PATTERNS.length; i++) {
            try {
                var found = await qz.printers.find(ZEBRA_PATTERNS[i]);
                _zebraPrinterName = found;
                console.log('[FedEx] Zebra printer found:', found);
                return found;
            } catch (e) { /* not found under this pattern, try next */ }
        }
        console.warn('[FedEx] No Zebra printer found. Tried:', ZEBRA_PATTERNS.join(', '));
        return null;
    }

    var _saveDir      = null;
    var _batchZip     = null;
    var _zipHasFiles  = false;
    var _batchTs      = '';
    var _allSaveTasks = [];

    const btnFedex   = document.getElementById('btn_fedex');
    const btnCsb4    = document.getElementById('btn_csb4');
    const divStatus  = document.getElementById('div_status');
    const statusText = document.getElementById('status_text');
    const divProg    = document.getElementById('div_progress');
    const progLabel  = document.getElementById('prog_label');
    const progFrac   = document.getElementById('prog_fraction');
    const progBar    = document.getElementById('prog_bar');
    const divResults = document.getElementById('div_results');
    const tblBody    = document.getElementById('tbl_body');
    const badgeDone  = document.getElementById('badge_done');
    const badgeSkip  = document.getElementById('badge_skip');
    const badgeErr   = document.getElementById('badge_err');

    let cntDone = 0, cntSkip = 0, cntErr = 0;

    let _pdfPrintWin = null; 
    var _baseHandleCache = null; 
    function _idbOpen() {
        return new Promise(function (resolve, reject) {
            var r = indexedDB.open('fedex_fs', 1);
            r.onupgradeneeded = function (e) { e.target.result.createObjectStore('h'); };
            r.onsuccess  = function (e) { resolve(e.target.result); };
            r.onerror    = function ()  { reject(); };
        });
    }
    async function _idbGet(key) {
        try {
            var db = await _idbOpen();
            return new Promise(function (resolve) {
                var tx = db.transaction('h', 'readonly');
                var q  = tx.objectStore('h').get(key);
                q.onsuccess = function () { resolve(q.result || null); };
                q.onerror   = function () { resolve(null); };
            });
        } catch (e) { return null; }
    }
    async function _idbSet(key, val) {
        try {
            var db = await _idbOpen();
            return new Promise(function (resolve) {
                var tx = db.transaction('h', 'readwrite');
                tx.objectStore('h').put(val, key);
                tx.oncomplete = resolve;
                tx.onerror    = resolve;
            });
        } catch (e) {}
    } 
    if (window.showDirectoryPicker) {
        _idbGet('base_dir').then(function (h) { _baseHandleCache = h; });
    }
 
    var _successInvoices = [];

    async function handleBatchClick(sheetType) {
        cntDone = 0; cntSkip = 0; cntErr = 0;
        _successInvoices = [];
        tblBody.innerHTML = '';

        if (_pdfPrintWin && !_pdfPrintWin.closed) _pdfPrintWin.close();
        _pdfPrintWin = window.open('about:blank', 'fedex_pdf_print',
            'width=900,height=700,left=100,top=50');
        if (_pdfPrintWin) {
            _pdfPrintWin.document.write(
                '<!DOCTYPE html><html><head><title>FedEx Print</title>'
                + '<style>'
                + 'body{margin:0;font-family:sans-serif;display:flex;align-items:center;'
                + 'justify-content:center;min-height:100vh;background:#f0f4f8}'
                + '.box{text-align:center;color:#555;padding:40px;max-width:400px}'
                + 'h3{color:#333;margin:0 0 10px;font-size:1.2rem}'
                + 'p{margin:0;font-size:13px;line-height:1.6}'
                + '</style></head><body>'
                + '<div class="box">'
                + '<h3>FedEx Print Window</h3>'
                + '<p>Shipment documents will appear here automatically for printing.<br>'
                + '<strong>Do not close this window</strong> until the batch is complete.</p>'
                + '</div></body></html>'
            );
            _pdfPrintWin.document.close();
        }

        _batchTs      = _nowStamp();
        _saveDir      = null;
        _zipHasFiles  = false;
        _allSaveTasks = [];
        _batchZip = window.JSZip ? new JSZip() : null;

        if (window.showDirectoryPicker) {
            var _permPromise = _baseHandleCache
                ? _baseHandleCache.requestPermission({ mode: 'readwrite' })
                      .catch(function () { return 'denied'; })
                : Promise.resolve('denied');

            var _permResult = await _permPromise;
            var _baseDir    = (_permResult === 'granted') ? _baseHandleCache : null;

            if (!_baseDir) {
                try {
                    _baseDir = await window.showDirectoryPicker({
                        startIn: _baseHandleCache || 'desktop',
                        mode:    'readwrite',
                    });
                    _baseHandleCache = _baseDir;
                    await _idbSet('base_dir', _baseDir);
                } catch (e) { _baseDir = null; }
            }

            if (_baseDir) {
                try {
                    _saveDir = await _baseDir.getDirectoryHandle(
                        'FedEx_' + _batchTs, { create: true }
                    );
                } catch (e) { _saveDir = null; }
            }
        }

        setLoading(true);
        setStatus('info', 'Connecting to server and reading Excel file…');
        showProgress(false);
        divResults.classList.remove('d-none');

        let rows;
        try {
            const res = await get('/fedex/batch/rows?sheet=' + sheetType + '&t=' + Date.now());
            rows = res;
        } catch (err) {
            setStatus('danger', 'Failed to read Excel rows: ' + err.message);
            setLoading(false);
            if (_pdfPrintWin && !_pdfPrintWin.closed) _pdfPrintWin.close();
            return;
        }

        if (!rows.length) {
            setStatus('warning', 'No rows with invoice numbers found in the Excel file.');
            setLoading(false);
            if (_pdfPrintWin && !_pdfPrintWin.closed) _pdfPrintWin.close();
            return;
        }

        const pending = rows.filter(r => !r.already_done);
        const skipped = rows.filter(r =>  r.already_done);

        skipped.forEach((r, i) => {
            const trId = addRow(i + 1, r, 'skipped');
            if (r.tracking || r.label_url || r.auxiliary_url || r.invoice_pdf_url) {
                rowDone(trId, r, true);
            }
        });
        cntSkip = skipped.length;
        updateBadges();

        if (!pending.length) {
            setStatus('success', 'All ' + rows.length + ' rows have already been processed.');
            setLoading(false);
            showTallyButton();
            if (_pdfPrintWin && !_pdfPrintWin.closed) _pdfPrintWin.close();
            return;
        }

        showProgress(true);
        setStatus('info', 'Processing ' + pending.length + ' shipment(s)…');

        if (window.qz) _qzConnect().then(function(c) {
            if (!c) return;
            _findZebraPrinter(); // cache Zebra name
            qz.printers.getDefault().then(function(p) { _defaultPrinterName = p; }); // cache default
        });

        var _printChain = Promise.resolve();

        for (let i = 0; i < pending.length; i++) {
            const row = pending[i];
            const rowNum = skipped.length + i + 1;
            const trId   = addRow(rowNum, row, 'processing');

            setProgress(i, pending.length, 'Processing ' + (i + 1) + ' / ' + pending.length + ': ' + row.invoice_number + ' (' + (row.recipient || '') + ')');

            try {
                const result = await post('/fedex/batch/process', {
                    invoice_number: row.invoice_number,
                    service_type:   document.getElementById('sel_service').value,
                    pickup_type:    document.getElementById('sel_pickup').value,
                    ship_date:      document.getElementById('inp_date').value,
                    batch_reset:    (i === 0),
                });

                rowDone(trId, result);
                cntDone++;
                if (result.invoice_number) {
                    _successInvoices.push(result.invoice_number);
                }

                const inv = (result.invoice_number || '').replace(/[^A-Za-z0-9_\-]/g, '_');
                const printItems = [
                    result.label_url       ? { url: result.label_url,       dname: inv + '_LABEL'   + extFrom(result.label_url) }   : null,
                    result.auxiliary_url   ? { url: result.auxiliary_url,   dname: inv + '_AUX'     + extFrom(result.auxiliary_url) } : null,
                    result.invoice_pdf_url ? { url: result.invoice_pdf_url, dname: inv + '_INVOICE.pdf' }                            : null,
                ].filter(Boolean);

                const rowBlobsP = Promise.all(printItems.map(async function(it) {
                    try {
                        var ctrl = new AbortController();
                        var tid  = setTimeout(function() { ctrl.abort(); }, 15000);
                        var r = await fetch(it.url, { credentials: 'same-origin', signal: ctrl.signal });
                        clearTimeout(tid);
                        return r.ok ? { item: it, blob: await r.blob() } : null;
                    } catch(e) { return null; }
                }));

                _printChain = _printChain.then(async function() {
                    var ready = (await rowBlobsP).filter(Boolean);
                    if (!ready.length) return;

                    var pngs = ready.filter(function(r) { return !/\.pdf$/i.test(r.item.url); });
                    var pdfs = ready.filter(function(r) { return  /\.pdf$/i.test(r.item.url); });

                    var allBlobs = pngs.concat(pdfs).map(function(r) { return r.blob; });
                    var allB64s  = await Promise.all(allBlobs.map(_blobToBase64));
                    var pngB64s  = allB64s.slice(0, pngs.length);
                    var pdfB64s  = allB64s.slice(pngs.length);
                    _allSaveTasks.push(Promise.all(ready.map(function(r) { return _saveFile(r.item.dname, r.blob); })));

                    var zebraOk   = pngs.length ? await _printPNGsBatchViaQZ(pngs.map(function(r){return r.blob;}), pngB64s) : true;
                    var invoiceOk = pdfs.length ? await _printInvoiceViaQZ(pdfs[0].blob, pdfB64s[0]) : true;

                    if (!zebraOk && pngs.length) {
                        try {
                            for (var k = 0; k < pngs.length; k++) {
                                await new Promise(function(resolve) { _printInSharedWin(pngs[k].item, resolve); });
                            }
                        } catch(fe) { console.warn('[FedEx] PNG fallback error:', fe.message || fe); }
                    }

                    if (!invoiceOk && pdfs.length) {
                        try {
                            var _invBlob = pdfs[0].blob;
                            await new Promise(function(resolve) {
                                var win = _pdfPrintWin;
                                if (!win || win.closed) { resolve(); return; }
                                var done = false;
                                var finish = function() { if (!done) { done = true; resolve(); } };
                                var bridge  = '__pw_' + (++_pwSeq);
                                var blobUrl = URL.createObjectURL(_invBlob);
                                window[bridge] = function() { delete window[bridge]; URL.revokeObjectURL(blobUrl); finish(); };
                                win.document.open();
                                win.document.write(
                                    '<!DOCTYPE html><html><head><style>'
                                    + '*{margin:0;padding:0;box-sizing:border-box}'
                                    + 'html,body{width:100%;height:100vh;overflow:hidden}'
                                    + 'iframe{display:block;width:100%;height:100vh;border:none}'
                                    + '</style></head><body>'
                                    + '<iframe src="' + blobUrl + '" id="pf"></iframe>'
                                    + '<script>(function(){'
                                    + 'var dn=false;'
                                    + 'function done(){if(dn)return;dn=true;try{window.opener["' + bridge + '"]();}catch(e){}}'
                                    + 'document.getElementById("pf").addEventListener("load",function(){'
                                    + 'setTimeout(function(){window.addEventListener("afterprint",done,{once:true});window.print();},200);});'
                                    + 'setTimeout(done,4000);'
                                    + '}())<\/script></body></html>'
                                );
                                win.document.close(); win.focus();
                                setTimeout(function() { if (window[bridge]) delete window[bridge]; if (!done) finish(); }, 5000);
                            });
                        } catch(fe) { console.warn('[FedEx] invoice fallback error:', fe.message || fe); }
                    }
                }).catch(function(e) {
                    console.warn('[FedEx] print chain step failed (row skipped):', e.message || e);
                });

            } catch (err) {
                rowError(trId, err.message);
                cntErr++;
            }

            updateBadges();
            setProgress(i + 1, pending.length, null);
        }

        setStatus('info', '<span class="spinner-border spinner-border-sm mr-1"></span> Shipments created — printing remaining labels…');
        await _printChain; 
        await Promise.all(_allSaveTasks); 

        progBar.classList.remove('progress-bar-animated');
        const summary = cntDone + ' label(s) generated' +
            (cntSkip ? ', ' + cntSkip + ' skipped' : '') +
            (cntErr  ? ', ' + cntErr  + ' error(s)' : '');
        setStatus(cntErr ? 'warning' : 'success', '&#10003; Finished — ' + summary);
        setLoading(false);
        document.getElementById('div_tally').classList.remove('d-none');

        if (_zipHasFiles && _batchZip) {
            _batchZip.generateAsync({ type: 'blob' }).then(function (zipBlob) {
                _blobDownload('FedEx_' + _batchTs + '.zip', zipBlob);
            });
        } else if (_saveDir && cntDone > 0) {
            var folderName = 'FedEx_' + _batchTs;
            setStatus(cntErr ? 'warning' : 'success',
                '&#10003; Finished — ' + summary + '. Files saved to <strong>' + folderName + '</strong> folder on Desktop.');
        } 
        if (_pdfPrintWin && !_pdfPrintWin.closed) _pdfPrintWin.close();
    }

    function showTallyButton() {
        var baseUrl = '{{ route('fedex.batch.tally.export') }}';
        var link = document.getElementById('btn_tally_xls');
        if (_successInvoices.length > 0) {
