    /* ── HTTP helpers ── */
    async function get(url) {
        const res = await fetch(url, {
            credentials: 'same-origin',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        });
        const body = await res.json();
        if (!res.ok) throw new Error(body.error || ('HTTP ' + res.status));
        return body;
    }

    async function post(url, data) {
        const csrf = document.querySelector('meta[name="csrf-token"]');
        const res  = await fetch(url, {
            method:      'POST',
            credentials: 'same-origin',
            headers: {
                'Content-Type':  'application/json',
                'Accept':        'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                'X-CSRF-TOKEN':  csrf ? csrf.content : '',
            },
            body: JSON.stringify(data),
        });
        const text = await res.text();
        let body = {};
        try { body = JSON.parse(text); } catch (e) { body = { error: 'HTTP ' + res.status + ': ' + text.substring(0, 300) }; }
        if (!res.ok) throw new Error(body.error || ('HTTP ' + res.status));
        return body;
    }

    /* ── Table helpers ── */
    let rowSeq = 0;
    function addRow(num, row, status) {
        const id = 'tr_' + (rowSeq++);
        const tr = document.createElement('tr');
        tr.id = id;
        tr.innerHTML =
            '<td class="text-center text-muted">' + num + '</td>' +
            '<td class="font-weight-bold">' + esc(row.invoice_number) + '</td>' +
            '<td>' + esc(row.recipient || '') + '</td>' +
            '<td>' + esc(row.country || '') + '</td>' +
            '<td class="td-track">—</td>' +
            '<td class="td-print">—</td>' +
            '<td class="td-status">' + badge(status) + '</td>';
        tblBody.appendChild(tr);
        tr.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        return id;
    }

    function rowDone(id, result, keepBadge) {
        const tr = document.getElementById(id);
        if (!tr) return;
        tr.querySelector('.td-track').textContent = result.tracking || '—';
        const inv  = (result.invoice_number || '').replace(/[^A-Za-z0-9_\-]/g, '_');
        const btns = [];
        if (result.invoice_pdf_url) btns.push(ptdBtn(result.invoice_pdf_url, inv + '_INVOICE.pdf',                          'btn-outline-secondary',    'Invoice'));
        if (result.label_url)       btns.push(ptdBtn(result.label_url,       inv + '_LABEL' + extFrom(result.label_url),     'btn-outline-primary ml-1', 'Label'));
        if (result.auxiliary_url)   btns.push(ptdBtn(result.auxiliary_url,   inv + '_AUX'   + extFrom(result.auxiliary_url), 'btn-outline-warning btn-outline-aux ml-1', 'Auxiliary'));
        tr.querySelector('.td-print').innerHTML = btns.join('') || '—';
        if (!keepBadge) {
            tr.querySelector('.td-status').innerHTML = badge('done');
            tr.classList.add('table-success');
        }
    }

    function ptdBtn(url, dname, cls, label) {
        return '<button class="btn btn-sm ' + cls + ' btn-ptd"'
            + ' data-url="' + esc(url) + '"'
            + ' data-dname="' + esc(dname) + '">'
            + label + '</button>';
    }

    function directDownload(url, dname) {
        const a = document.createElement('a');
        a.href     = url;
        a.download = dname;
        a.rel      = 'noopener';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    }

    async function printThenDownload(url, dname) { 
        const isPng = /\.png$/i.test(url); 
        const win = window.open('about:blank', '_blank');
        if (!win) {
            alert('Popups are blocked. Please allow popups for this site and try again.');
            return;
        }
        win.document.write('<p style="font-family:sans-serif;padding:20px;">Loading…</p>');

        let blob;
        try {
            const res = await fetch(url, { credentials: 'same-origin' });
            if (!res.ok) {
                win.close();
                const msg = res.status === 410
                    ? 'Label URL has expired. Please re-run the batch to get a fresh label.'
                    : 'Could not load label (HTTP ' + res.status + '). Please re-run the batch.';
                alert(msg);
                return;
            }
            blob = await res.blob();
        } catch (e) {
            win.close();
            alert('Failed to load label: ' + e.message);
            return;
        } 
        var dlUrl = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = dlUrl; a.download = dname;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        setTimeout(function () { URL.revokeObjectURL(dlUrl); }, 5000); 
        if (isPng || blob.type === 'image/png') {
            printPngInWindow(blob, win);
        } else {
            printPdfInWindow(url, win);
        }
    }

    tblBody.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-ptd');
        if (!btn) return;
        printThenDownload(btn.dataset.url, btn.dataset.dname);
    });

    function rowError(id, msg) {
        const tr = document.getElementById(id);
        if (!tr) return;
        tr.querySelector('.td-status').innerHTML =
            '<span class="badge badge-danger">Error</span><br>' +
            '<small class="text-danger err-detail">' + esc(msg.substring(0, 300)) + '</small>';
        tr.classList.add('table-danger');
    }

    function badge(s) {
