    function _pemToDer(b64) {
        var bin = atob(b64);
        var buf = new Uint8Array(bin.length);
        for (var i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
        return buf.buffer;
    }

    function _qzConfigure() {
        if (!window.qz) return;
        qz.security.setCertificatePromise(function (resolve) { resolve(_QZ_CERT); });
        qz.security.setSignaturePromise(function (toSign) {
            return function (resolve, reject) {
                crypto.subtle.importKey(
                    'pkcs8', _pemToDer(_QZ_KEY),
                    { name: 'RSASSA-PKCS1-v1_5', hash: 'SHA-1' },
                    false, ['sign']
                ).then(function (key) {
                    return crypto.subtle.sign(
                        'RSASSA-PKCS1-v1_5', key,
                        new TextEncoder().encode(toSign)
                    );
                }).then(function (sig) {
                    var arr = new Uint8Array(sig);
                    resolve(btoa(String.fromCharCode.apply(null, arr)));
                }).catch(reject);
            };
        });
    }

    /* Returns true if QZ Tray is installed and reachable */
    async function _qzConnect() {
        if (!window.qz) return false;
        if (qz.websocket.isActive()) return true;
        _qzConfigure();
        try {
            await qz.websocket.connect({ retries: 1, delay: 0.5 });
            return true;
        } catch (e) { return false; }
    }

    /* Convert a Blob to a base64 data string (without the data: prefix) */
    function _blobToBase64(blob) {
        return new Promise(function (resolve, reject) {
            var r = new FileReader();
            r.onload  = function () { resolve(r.result.split(',')[1]); };
            r.onerror = reject;
            r.readAsDataURL(blob);
        });
    }

    function _withTimeout(promise, ms) {
        return Promise.race([
            promise,
            new Promise(function(_, reject) {
                setTimeout(function() { reject(new Error('QZ timeout after ' + ms + 'ms')); }, ms);
            })
        ]);
    }

    async function _printInvoiceViaQZ(blob, preB64) {
        if (!await _qzConnect()) return false;
        try {
            if (!_defaultPrinterName) {
                _defaultPrinterName = await _withTimeout(qz.printers.getDefault(), 3000);
            }
            if (!_defaultPrinterName) return false; 
            var cfg = qz.configs.create(_defaultPrinterName, {
                copies:    1,
                colorType: 'color',
                units:  'in',
                margins:   { top: 0, right: 0.2, bottom: 0, left: 0.1 }
            });

            var b64 = preB64 || await _blobToBase64(blob);
            await _withTimeout(qz.print(cfg, [{ type: 'pixel', format: 'pdf', flavor: 'base64', data: b64 }]), 5000);
            return true;
        } catch (e) {
            console.warn('[FedEx] QZ invoice failed (' + e.message + ') — window fallback');
            _defaultPrinterName = null; // reset so next row re-discovers
            return false;
        }
    }

    async function _printPNGsBatchViaQZ(blobs, preB64s) {
        if (!blobs.length) return true;
        if (!await _qzConnect()) return false;
        try {
            var printer = await _findZebraPrinter();
            if (!printer) return false;
            var cfg = qz.configs.create(printer, {
                size:      { width: 4, height: 6 },
                units:     'in',
                density:   203, 
                margins:   { top: 0, right: 0, bottom: 0, left: 0.1 },
                colorType: 'grayscale',
                copies:    1
            });
            var b64s = preB64s || await Promise.all(blobs.map(_blobToBase64));
            await _withTimeout(qz.print(cfg, b64s.map(function(b) {
                return { type: 'pixel', format: 'image', flavor: 'base64', data: b };
            })), 5000);
            return true;
        } catch (e) {
            console.warn('[FedEx] QZ PNG batch failed (' + e.message + ')');
            return false;
        }
    }

    /* Print a single PNG blob via QZ Tray (used for manual button clicks). */ 
    async function _printViaQZ(blob) {
        if (!await _qzConnect()) return false;
        try {
            var printer = await _findZebraPrinter();
            if (!printer) return false;
            var cfg = qz.configs.create(printer, {
                size:      { width: 4, height: 6 },
                units:     'in',
                density:   203,
                margins:   { top: 0, right: 0, bottom: 0, left: 0.1 },
                colorType: 'grayscale',
                copies:    1
            });
            var b64 = await _blobToBase64(blob);
            await _withTimeout(qz.print(cfg, [{ type: 'pixel', format: 'image', flavor: 'base64', data: b64 }]), 5000);
            return true;
        } catch (e) {
            console.warn('QZ label print failed:', e.message || e);
            return false;
        }
    }

    /* ── File save helper ────────────────────────────────────────────────────────
       1st try : write into Desktop folder via File System Access API
       2nd try : add to JSZip (downloaded as one .zip at batch end)
       3rd try : direct blob download (individual file, goes to Downloads)       */
    async function _saveFile(name, blob) {
        if (_saveDir) {
            try {
                var fh = await _saveDir.getFileHandle(name, { create: true });
                var wr = await fh.createWritable();
                await wr.write(blob);
                await wr.close();
                return; // saved to Desktop folder — done
            } catch (e) {
                console.warn('[FedEx] folder write failed, falling back:', name, e.message || e);
            }
        }
        if (_batchZip) {
            _batchZip.file(name, blob);
            _zipHasFiles = true;
            return; // queued for ZIP
        }
        /* Last resort: trigger individual browser download */
        _blobDownload(name, blob);
    }

    function _blobDownload(name, blob) {
        var url = URL.createObjectURL(blob);
        var a   = document.createElement('a');
        a.href = url; a.download = name;
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
        setTimeout(function () { URL.revokeObjectURL(url); }, 8000);
    }

    var _pwSeq = 0;

    /* Fallback PNG print via shared window (used when QZ Tray is not available).
       Navigates the shared window to /fedex/print/label which shows the image
       and auto-prints it; signals back via window.opener[bridge]() after afterprint. */
    function _printInSharedWin(item, onDone) {
        var win = _pdfPrintWin;
        if (!win || win.closed) { onDone(); return; }

        var done = false;
        var finish = function () {
            if (done) return;
            done = true;
            onDone();
        };

        var bridge = '__pw_' + (++_pwSeq);
        window[bridge] = function () {
            delete window[bridge];
            finish();
        };
        win.location.href = '/fedex/print/label'
            + '?url=' + encodeURIComponent(item.url)
            + '&cb='  + encodeURIComponent(bridge);

        /* Fallback if afterprint never fires (e.g. user cancels or QZ timeout) */
        setTimeout(function () {
            if (window[bridge]) { delete window[bridge]; }
            if (!done) finish();
        }, 20000);

        setTimeout(finish, 30000); /* absolute safety net */
    }

    /* ── Manual button print (Print / Download buttons in the table) ─────────── */

    /* Write PNG blob into an already-open window and trigger print */
    function printPngInWindow(blob, win) {
        var blobUrl = URL.createObjectURL(blob);
        win.document.open();
        win.document.write('<!DOCTYPE html><html><head><style>'
            + '*{margin:0;padding:0;box-sizing:border-box}'
            /* Screen: native resolution — no downscaling, keeps INV/PO/REF/DEPT sharp */
            + '@media screen{html,body{background:#fff}'
            + 'img{display:block;width:100%;height:auto;'
            + 'image-rendering:-webkit-optimize-contrast;image-rendering:crisp-edges}}'
            /* Print: exact 4×6 label dimensions */
            + '@media print{'
            + '@page{size:4in 6in;margin:0}'
            + 'html,body{width:4in;height:6in;overflow:hidden}'
            + 'img{display:block;width:4in;height:6in;object-fit:contain}}'
            + '</style></head><body>'
            + '<img src="' + blobUrl + '" onload="window.print()">'
            + '</body></html>');
        win.document.close();
        win.focus();
        win.addEventListener('afterprint', function () {
            URL.revokeObjectURL(blobUrl);
            win.close();
        });
    }

    /* Manual PDF button: navigate to server URL — not blob URL, which Chrome
       downloads instead of rendering, producing a second unwanted file. */
    function printPdfInWindow(serverUrl, win) {
        win.location.href = serverUrl;
        win.focus();
        try {
            win.addEventListener('load', function () { try { win.print(); } catch (e) {} });
        } catch (e) {}
    }

    /* ── Utilities ── */
    function _nowStamp() {
        var d = new Date(), p = function (n) { return n < 10 ? '0' + n : n; };
        return d.getFullYear() + '' + p(d.getMonth() + 1) + '' + p(d.getDate())
             + '_' + p(d.getHours()) + '' + p(d.getMinutes()) + '' + p(d.getSeconds());
    }

    function esc(s) {
        return String(s)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
